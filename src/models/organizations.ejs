<%- include('partials/header') %>

    <main>
        <h1>
            <%= title %>
        </h1>

        <% organizations.forEach(org=> { %>
            <div>
                <img src="/images/<%= org.logo_filename %>" alt="<%= org.name %> logo">
                <h2>
                    <%= org.name %>
                </h2>
                <p>
                    <%= org.description %>
                </p>
                <p>Contact: <a href="mailto:<%= org.contact_email %>">
                        <%= org.contact_email %>
                    </a></p>
            </div>
            <% }) %>
    </main>

    <%- include('partials/footer') %>